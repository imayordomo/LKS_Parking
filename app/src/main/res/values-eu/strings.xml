    <!-- Help Screen -->
    <string name="help_title">Laguntza</string>
    <string name="help_subtitle">Maiz egiten diren galderak</string>
    <string name="faq_q1">Nola egiten dut erreserba bat?</string>
    <string name="faq_a1">Joan \"Erreserbak\" atalera eta sakatu \"+\" botoi mugikorra. Hautatu data, hasiera eta amaiera ordua, aukeratu plaza libre bat (berdea) eta baieztatu. Gutxienez ibilgailu bat erregistratuta izan behar duzu erreserbatu ahal izateko.</string>
    <string name="faq_q2">Zenbateko aurrerapenarekin erreserbatu dezaket?</string>
    <string name="faq_a2">Gehienez 7 eguneko aurrerapenarekin egin ditzakezu erreserbak.</string>
    <string name="faq_q3">Zenbat denboraz erreserbatu dezaket plaza bat?</string>
    <string name="faq_a3">Saio bakoitzeko erreserba-denbora handiena 9 ordukoa da.</string>
    <string name="faq_q4">Zer plaza mota daude?</string>
    <string name="faq_a4">Aparkalekuak 50 plaza ditu: plaza arruntak, ibilgailu elektrikoentzako plazak (kargagailuarekin), motoentzako plazak eta mugikortasun murriztuko pertsonentzako egokitutako plazak. Plaza bakoitza dagokion ikonoarekin identifikatuta dago.</string>
    <string name="faq_q5">Ikusi dezaket nork erreserbatu duen plaza bat?</string>
    <string name="faq_a5">Bai, \"Aparkalekua Kontsultatu\" atalean data bat hautatu eta betetako plazak ikusi ditzakezu. Betetako plaza batean klik eginez, nork erreserbatu duen eta bere matrikula ikusiko duzu.</string>
    <string name="faq_q6">Nola gehitzen dut ibilgailu bat?</string>
    <string name="faq_a6">Joan \"Profila eta Ibilgailuak\" atalera eta sakatu \"Gehitu Ibilgailua\" botoia. Hautatu ibilgailu mota (autoa, elektrikoa, motoa edo desgaitua) eta sartu matrikula. Gutxienez ibilgailu bat erregistratuta izan behar duzu erreserbak egin ahal izateko.</string>
    <string name="faq_q7">Nola jakinarazten dut arazo bat?</string>
    <string name="faq_a7">Erabili menuko \"Jakinarazi\" atala. Hautatu arazo mota (garbiketa, kalteak, argiztapena, segurtasuna edo beste bat), adierazi plaza zenbakia badagokio, eta azaldu arazoa ahalik eta xehetasun gehienekin.</string>
    <string name="faq_q8">Nola funtzionatzen dute jakinarazpenek?</string>
    <string name="faq_a8">Aplikazioak zure hurrengo erreserbei, gogorarazpenei eta baieztapenei buruzko jakinarazpenekin informatuta mantentzen zaitu. Zure jakinarazpen guztiak ikus ditzakezu goiko barrako kanpai ikonoan klik eginez.</string>
    <string name="faq_q9">Erreserba bat bertan behera utzi dezaket?</string>
    <string name="faq_a9">Bai, zure erreserbak bertan behera utzi ditzakezu \"Erreserbak\" ataletik. Hedatu bertan behera utzi nahi duzun erreserba eta sakatu ezabatzeko botoia. Kontuan izan ekintza hau ezin dela desegin.</string>
    <string name="faq_q10">Zer egiten dut nire emaila @lksnext.com ez bada?</string>
    <string name="faq_a10">\@lksnext.com posta korporatiboa duten langileek bakarrik erregistratu daitezke sisteman. Sarbidea behar baduzu eta posta hori ez baduzu, jarri harremanetan facilities sailarekin.</string>
    <string name="faq_q11">Zer esan nahi dute koloreek Aparkalekua Kontsultatu atalean?</string>
    <string name="faq_a11">Aparkalekuaren ikuspegian, plazak hiru koloretan agertzen dira:\n\n• Berdea = Eskuragarri: inork ez du plaza erreserbatu ordu horretan.\n• Horia = Zure erreserba: erreserba aktibo bat duzu plaza horretan.\n• Grisa = Okupatua: beste erabiltzaile batek plaza hori erreserbatu du.</string>
    <string name="faq_q12">Zergatik aldatzen dira plaza okupatuak gaur eta beste egun batean ikustean?</string>
    <string name="faq_a12">Gaurko eguna hautatzen duzunean, une honetan erreserba aktibo bat duten plazak soilik agertzen dira okupatuta. Erreserba bat beranduago hasten bada, plaza librea agertuko da ordu horretara arte. Etorkizuneko egun bat hautatzean, egun horretarako programatutako erreserba guztiak erakusten dira, ordua kontuan hartu gabe.</string>
    <string name="more_help_title">Laguntza gehiago behar duzu?</string>
    <string name="more_help_desc">Jarri harremanetan facilities sailarekin example@lksnext.com helbidean edo deitu 1234 luzapenera</string>

